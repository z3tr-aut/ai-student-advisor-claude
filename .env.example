# ═══════════════════════════════════════════════════════════════════════
#   AI Student Advisor — Environment Variables
#   Copy this file to `.env.local` and fill in the values.
# ═══════════════════════════════════════════════════════════════════════

# ─── Supabase ──────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → Data API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Supabase Dashboard → Project Settings → API Keys → anon public
# This key is safe to expose in the browser (RLS protects your data).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Google Gemini ─────────────────────────────────────────────────────
# Get this from: https://aistudio.google.com → Get API key
# Free tier: 1,500 requests/day, 15 requests/minute
# NEVER expose this in the browser — it is used only in server routes.
GEMINI_API_KEY=AIza...

# Optional: override the default model (free tier).
# Defaults to gemini-1.5-flash if unset.
# GEMINI_MODEL=gemini-1.5-flash

# ─── App ───────────────────────────────────────────────────────────────
# Used for email confirmation callbacks. Set to your deployed URL in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
