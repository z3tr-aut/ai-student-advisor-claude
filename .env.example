# ═══════════════════════════════════════════════════════════════════════
#   AI Student Advisor — Environment Variables
#   Copy this file to `.env.local` and fill in the values.
# ═══════════════════════════════════════════════════════════════════════

# ─── Supabase ──────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → Data API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Supabase Dashboard → Project Settings → API Keys → anon public
# This key is safe to expose in the browser (RLS protects your data).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Anthropic (Claude) ────────────────────────────────────────────────
# Get this from: https://console.anthropic.com/settings/keys
# NEVER expose this in the browser — it is used only in server routes.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: override the default model.
# Defaults to claude-3-5-sonnet-latest if unset.
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ─── App ───────────────────────────────────────────────────────────────
# Used for email confirmation callbacks. Set to your deployed URL in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
